# name: test/sql/http_client_local.test
# description: Test http_client extension (no external services)
# group: [http_client]

require http_client

# ---------------------------------------------------------------------------
# negotiate_auth_header: error cases (no network needed)
# ---------------------------------------------------------------------------

statement error
SELECT negotiate_auth_header('http://example.com');
----
Negotiate authentication requires HTTPS

statement error
SELECT negotiate_auth_header('not-a-url');
----
Invalid URL

statement error
SELECT negotiate_auth_header_json('http://example.com');
----
Negotiate authentication requires HTTPS

statement error
SELECT negotiate_auth_header_json('not-a-url');
----
Invalid URL

# ---------------------------------------------------------------------------
# Config helpers: http_config_set, _get, _remove, _set_bearer
# ---------------------------------------------------------------------------

# Start with no config
query I
SELECT http_config_get('https://api.example.com/');
----
NULL

# Set a scope
statement ok
SET VARIABLE http_config = http_config_set(
    'https://api.example.com/',
    json_object('auth_type', 'bearer', 'bearer_token', 'tok123')
);

# Read it back
query I
SELECT json_extract_string(http_config_get('https://api.example.com/'), '$.auth_type');
----
bearer

# Set a second scope — first scope preserved
statement ok
SET VARIABLE http_config = http_config_set(
    'https://other.com/',
    json_object('timeout', 60)
);

query I
SELECT json_extract_string(http_config_get('https://api.example.com/'), '$.bearer_token');
----
tok123

query I
SELECT json_extract(http_config_get('https://other.com/'), '$.timeout');
----
60

# Remove a scope — other scope preserved
statement ok
SET VARIABLE http_config = http_config_remove('https://other.com/');

query I
SELECT http_config_get('https://other.com/');
----
NULL

query I
SELECT json_extract_string(http_config_get('https://api.example.com/'), '$.bearer_token');
----
tok123

# ---------------------------------------------------------------------------
# http_config_set_bearer: convenience macro
# ---------------------------------------------------------------------------

# Without expiry
statement ok
SET VARIABLE http_config = http_config_set_bearer(
    'https://vendor.com/', 'eyJtoken'
);

query I
SELECT json_extract_string(http_config_get('https://vendor.com/'), '$.auth_type');
----
bearer

query I
SELECT json_extract_string(http_config_get('https://vendor.com/'), '$.bearer_token');
----
eyJtoken

# With expiry
statement ok
SET VARIABLE http_config = http_config_set_bearer(
    'https://vendor.com/', 'eyJnew', expires_at := 1741564800
);

query I
SELECT json_extract(http_config_get('https://vendor.com/'), '$.bearer_token_expires_at');
----
1741564800

# Overwrite preserves other scopes
query I
SELECT json_extract_string(http_config_get('https://api.example.com/'), '$.bearer_token');
----
tok123

# ---------------------------------------------------------------------------
# Domain-suffix matching: scope applies to subdomains
# ---------------------------------------------------------------------------

# Set config for a base domain
statement ok
SET VARIABLE http_config = http_config_set(
    'https://acmecorp.test',
    json_object('auth_type', 'negotiate')
);

# An expired bearer on a subdomain proves the domain-suffix match resolved the config
statement ok
SET VARIABLE http_config = http_config_set(
    'https://acmecorp.test',
    json_object('auth_type', 'bearer', 'bearer_token', 'tok', 'bearer_token_expires_at', 1)
);

statement error
SELECT r.response_status_code
FROM (SELECT http_get('https://sub.acmecorp.test/path') AS r);
----
Bearer token for sub.acmecorp.test expired at

# Prefix match takes priority over domain-suffix match
statement ok
SET VARIABLE http_config = http_config_set(
    'https://sub.acmecorp.test/',
    json_object('auth_type', 'bearer', 'bearer_token', 'specific', 'bearer_token_expires_at', 2)
);

statement error
SELECT r.response_status_code
FROM (SELECT http_get('https://sub.acmecorp.test/path') AS r);
----
Bearer token for sub.acmecorp.test expired at

# Clean up before next section
statement ok
SET VARIABLE http_config = MAP {};

# ---------------------------------------------------------------------------
# Bearer token expiry: expired token raises error
# ---------------------------------------------------------------------------

# Set a token that expired in the past (epoch 1 = 1970-01-01T00:00:01Z)
statement ok
SET VARIABLE http_config = http_config_set_bearer(
    'http://localhost:9999/', 'expired_token', expires_at := 1
);

statement error
SELECT r.response_status_code
FROM (SELECT http_get('http://localhost:9999/anything') AS r);
----
Bearer token for localhost expired at

# ---------------------------------------------------------------------------
# Clean up
# ---------------------------------------------------------------------------

statement ok
SET VARIABLE http_config = MAP {};
